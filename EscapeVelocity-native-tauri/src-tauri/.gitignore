# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Pre-warmed Tectonic cache (large, generated). Bundled into the app at build
# time as a resource; regenerate with `npm run prewarm` before `tauri build`.
# Keep the directory (with .gitkeep) so tauri-build's resource path always
# exists; ignore only the generated contents.
/vendor/tectonic-cache/*
!/vendor/tectonic-cache/.gitkeep
